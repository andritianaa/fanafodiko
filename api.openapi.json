                }
              }
            }
          }
        }
      }
    },
    "/notifications/tasks": {
      "get": {
        "security": [
          {
            "AuthorizationApiKey": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Profile ID"
            },
            "required": true,
            "name": "profileId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Date in YYYY-MM-DD format"
            },
            "required": false,
            "name": "date",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of medication tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "medicationId": {
                        "type": "string"
                      },
                      "profileId": {
                        "type": "string"
                      },
                      "scheduledAt": {
