                    "lastName": {
                      "type": "string",
                      "example": "Doe"
                    },
                    "dateOfBirth": {
                      "type": "string",
                      "example": "1990-01-01T00:00:00.000Z"
                    },
                    "relationship": {
                      "type": "string",
                      "example": "child"
                    },
                    "avatarUrl": {
                      "type": "string",
