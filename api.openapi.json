{
  "openapi": "3.0.0",
  "info": {
    "title": "My Backend API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "security": [
    {
      "Bearer": []
    }
  ],
  "components": {
    "securitySchemes": {
      "AuthorizationApiKey": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    },
    "schemas": {
      "Frequency": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "DAILY",
              "WEEKLY",
              "INTERVAL"
            ],
            "description": "Frequency type",
            "example": "DAILY"
          },
          "times": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of times in HH:mm format",
            "example": [
              "08:00",
              "20:00"
            ]
          },
          "days": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of days (required for WEEKLY)",
            "example": [
              "MONDAY",
              "THURSDAY"
            ]
          }
        },
        "required": [
          "type",
          "times"
        ]
      },
      "MedicationResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "medication-uuid"
          },
          "profileId": {
            "type": "string",
            "example": "profile-uuid"
          },
          "name": {
            "type": "string",
            "example": "Doliprane"
          },
          "dosage": {
            "type": "string",
            "example": "500mg"
          },
          "frequency": {
            "$ref": "#/components/schemas/Frequency"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "nullable": true,
            "format": "date-time"
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "profileId",
          "name",
          "dosage",
          "frequency",
          "startDate",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateMedication": {
        "type": "object",
        "properties": {
          "profileId": {
            "type": "string",
            "description": "ID associated profile",
            "example": "profile-uuid"
          },
          "name": {
            "type": "string",
            "description": "Medication name",
            "example": "Doliprane"
          },
          "dosage": {
            "type": "string",
            "description": "Dosage instructions",
            "example": "500mg"
          },
          "frequency": {
            "$ref": "#/components/schemas/Frequency"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "Start date",
            "example": "2023-01-01T00:00:00Z"
          },
          "endDate": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "End date (optional)",
            "example": "2023-01-10T00:00:00Z"
          }
        },
        "required": [
          "profileId",
          "name",
          "dosage",
          "frequency",
          "startDate"
        ]
      },
      "MedicationList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/MedicationResponse"
        }
      },
      "UpdateMedication": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Medication name",
            "example": "Doliprane"
          },
          "dosage": {
            "type": "string",
            "description": "Dosage instructions",
            "example": "1000mg"
          },
          "frequency": {
            "$ref": "#/components/schemas/Frequency"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "description": "Start date",
            "example": "2023-01-01T00:00:00Z"
          },
          "endDate": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "End date (optional)",
            "example": "2023-01-10T00:00:00Z"
          }
        }
      },
      "ToggleMedicationStatus": {
        "type": "object",
        "properties": {
          "isActive": {
            "type": "boolean",
            "description": "True to activate, False to pause",
            "example": false
          }
        },
        "required": [
          "isActive"
        ]
      }
    },
    "parameters": {

    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 255,
                    "format": "email",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128,
                    "pattern": "[a-z]",
                    "example": "Password123!"
                  },
                  "firstName": {
                    "type": "string",
                    "example": "John"
                  },
                  "lastName": {
                    "type": "string",
                    "example": "Doe"
                  },
                  "dateOfBirth": {
                    "type": "string",
                    "nullable": true,
                    "example": "1990-01-01"
                  }
                },
                "required": [
                  "email",
                  "password",
                  "firstName",
                  "lastName"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "65f1a..."
                    },
                    "email": {
                      "type": "string",
                      "format": "email",
                      "example": "user@example.com"
                    },
                    "message": {
                      "type": "string",
                      "example": "User created successfully"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "message"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid input"
          },
          "409": {
            "description": "User already exists"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 255,
                    "format": "email",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 128,
                    "pattern": "[a-z]",
                    "example": "Password123!"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR..."
                    }
                  },
                  "required": [
                    "token"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {

                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    },
    "/auth/password/reset": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "The email address to send the reset link to",
                    "example": "john.doe@example.com"
                  }
                },
                "required": [
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset link sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "If an account with that email exists, a reset link has been sent."
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/auth/password/confirm": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string",
                    "minLength": 1,
                    "description": "The reset code received via email",
                    "example": "123456"
                  },
                  "newPassword": {
                    "type": "string",
                    "minLength": 8,
                    "description": "The new password",
                    "example": "NewPassword123!"
                  }
                },
                "required": [
                  "code",
                  "newPassword"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Password has been successfully reset."
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid code"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "security": [
          {
            "AuthorizationApiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "65f1a..."
                    },
                    "email": {
                      "type": "string",
                      "format": "email",
                      "example": "user@example.com"
                    },
                    "message": {
                      "type": "string",
                      "example": "User created successfully"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/households": {
