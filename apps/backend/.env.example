MONGODB_URI=mongodb://localhost:27017/myapp

RESEND_API_KEY=re_xxxxxx

PORT=3000
NODE_ENV=development
SOURCE_URL=http://localhost:3000

RESEND_DOMAIN_NAME=your_domain.com

# URL du frontend web (liens emails : invitations pharmacie, revue des demandes)
FRONTEND_URL=http://localhost:5173

# Destinataire des notifications de nouvelles demandes de pharmacie.
# Si vide, tous les utilisateurs ayant le rôle plateforme admin/support sont notifiés.
PLATFORM_ADMIN_EMAIL=

# JWT,durée de vie du token de session (365d = 1 an, indéfini en pratique)
# Formats acceptés : Xh (heures), Xd (jours), Xm (minutes), ou nombre de secondes
JWT_EXPIRES_IN=7300d

JWT_SECRET=my-secret-key
